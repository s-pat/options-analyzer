# ── Go API environment variables ─────────────────────────────────────────────
# Copy this file to .env and adjust for your environment.
# Never commit .env — it is gitignored.

# HTTP port the server listens on (Railway sets this automatically)
PORT=8080

# gRPC port (internal only, not publicly exposed on Railway)
GRPC_PORT=9090

# Gin mode: "debug" for local dev, "release" for production
GIN_MODE=debug

# Comma-separated list of allowed CORS origins.
# In production, set this to your Vercel frontend URL.
# Example: https://optionslab.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Market data source ────────────────────────────────────────────────────────
# DATA_SOURCE selects the market-data backend.
# Supported values: "yahoo" (default, no key required) | "alphavantage"
DATA_SOURCE=yahoo

# Required when DATA_SOURCE=alphavantage
# Get a free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Set to "true" if you have an AlphaVantage premium key (removes rate-limit delay)
ALPHA_VANTAGE_PREMIUM=false
